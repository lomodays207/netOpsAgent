# 鑷姩鍖栧钩鍙癆PI閰嶇疆
AUTOMATION_API_URL=http://localhost:8080/api/v1
AUTOMATION_API_TOKEN=your-api-token-here

# CMDB API閰嶇疆
CMDB_API_URL=http://localhost:8081/api/v1
CMDB_API_TOKEN=your-cmdb-token-here

# Openai LLM API閰嶇疆 (Phase 2)
API_KEY=ms-3137a52f-c25c-42b8-8437-fed4bc4eb5b1
API_BASE_URL=https://api-inference.modelscope.cn/v1
MODEL=deepseek-ai/DeepSeek-V3.2

# LLM Agent 閰嶇疆
LLM_AGENT_MAX_STEPS=10  # LLM Agent 鏈€澶ф墽琛屾鏁帮紝寤鸿 10-20
LLM_AGENT_TEMPERATURE=0.3  # LLM 娓╁害鍙傛暟锛屽缓璁?0.1-0.5
LLM_REQUEST_TIMEOUT=60  # LLM API 璇锋眰瓒呮椂鏃堕棿锛堢锛?
LLM_MAX_RETRIES=3  # LLM API 璇锋眰澶辫触閲嶈瘯娆℃暟

# Intent router 閰嶇疆
INTENT_ROUTER_MODE=rule  # rule | hybrid
INTENT_LLM_MIN_CONFIDENCE=0.80
INTENT_LLM_DIAGNOSIS_MIN_CONFIDENCE=0.85
INTENT_LOG_DECISIONS=false

# 鏃ュ織閰嶇疆
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json # json | console

# 杩愯妯″紡
APP_ENV=development  # development | production

# 瓒呮椂閰嶇疆
DEFAULT_COMMAND_TIMEOUT=30
MAX_RETRY_ATTEMPTS=3

# 骞跺彂閰嶇疆
MAX_CONCURRENT_COMMANDS=10
