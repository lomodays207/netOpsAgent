# Automation platform API config
AUTOMATION_API_URL=http://localhost:8080/api/v1
AUTOMATION_API_TOKEN=your-api-token-here

# CMDB API config
CMDB_API_URL=http://localhost:8081/api/v1
CMDB_API_TOKEN=your-cmdb-token-here

# OpenAI LLM API config (Phase 2)
API_KEY=your-llm-api-key-here
API_BASE_URL=https://api-inference.modelscope.cn/v1
MODEL=deepseek-ai/DeepSeek-V3.2

# LLM agent config
LLM_AGENT_MAX_STEPS=10  # LLM Agent max steps, recommended 10-20
LLM_AGENT_TEMPERATURE=0.3  # LLM temperature, recommended 0.1-0.5
LLM_REQUEST_TIMEOUT=60  # LLM API request timeout in seconds
LLM_MAX_RETRIES=3  # LLM API retry count

# Intent router config
INTENT_ROUTER_MODE=rule  # rule | hybrid
INTENT_LLM_MIN_CONFIDENCE=0.80
INTENT_LLM_DIAGNOSIS_MIN_CONFIDENCE=0.85
INTENT_LOG_DECISIONS=false

# Logging config
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json # json | console

# Runtime mode
APP_ENV=development  # development | production

# Timeout config
DEFAULT_COMMAND_TIMEOUT=30
MAX_RETRY_ATTEMPTS=3

# Concurrency config
MAX_CONCURRENT_COMMANDS=10
